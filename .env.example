# Beehiiv newsletter API
# Get API key: https://app.beehiiv.com/settings/integrations/api
BEEHIIV_API_KEY=

# Publication ID (z URL panelu lub Settings)
BEEHIIV_PUBLICATION_ID=

# Opcjonalnie: ID automatyzacji Beehiiv, która wysyła maila z dostępem do kursu.
# Puste = pomijamy enroll, kupujący i tak zostaje zapisany z linkiem w custom field.
BEEHIIV_DRUGI_MOZG_AUTOMATION_ID=

# EasyCart - checkout kursu Drugi Mozg
EASYCART_API_KEY=
EASYCART_WEBHOOK_SECRET=

# Sekret do podpisywania linkow dostepowych do /drugi-mozg/kurs (HMAC).
# Wygeneruj dlugi losowy ciag: `openssl rand -hex 32`
COURSE_ACCESS_SECRET=

# Publiczny link hostowanego checkoutu EasyCart (z panelu EasyCart).
# Tylko ten NEXT_PUBLIC_ trafia do przegladarki — to nie sekret, tylko link koszyka.
NEXT_PUBLIC_EASYCART_CHECKOUT_URL=
