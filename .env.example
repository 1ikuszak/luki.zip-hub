# Beehiiv newsletter API
# Get API key: https://app.beehiiv.com/settings/integrations/api
BEEHIIV_API_KEY=

# Publication ID (z URL panelu lub Settings)
BEEHIIV_PUBLICATION_ID=

# EasyCart - checkout kursu Drugi Mozg
EASYCART_API_KEY=
EASYCART_WEBHOOK_SECRET=

# Opcjonalnie: nadpisanie UUID produktu kursu (default w app/lib/easycart.ts)
# EASYCART_PRODUCT_ID=

# Sekret do podpisywania tokenow dostepu (magic linki + cookie sesji).
# Wygeneruj dlugi losowy ciag: `openssl rand -hex 32`
# UWAGA: zmiana sekretu uniewaznia WSZYSTKIE linki i sesje (twardy kill-switch).
COURSE_ACCESS_SECRET=

# Publiczny link hostowanego checkoutu EasyCart (z panelu EasyCart).
# Tylko ten NEXT_PUBLIC_ trafia do przegladarki - to nie sekret, tylko link koszyka.
NEXT_PUBLIC_EASYCART_CHECKOUT_URL=

# Resend - maile transakcyjne kursu (dostep po zakupie + magic login).
# Klucz: https://resend.com/api-keys. Pusty poza produkcja = mail loguje sie
# do konsoli (dev-fallback); na produkcji brak klucza = twardy blad dostawy.
RESEND_API_KEY=
RESEND_FROM=Luki <kurs@luki.zip>
RESEND_REPLY_TO=
